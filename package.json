{
  "name": "bdd-vscode-runner",
  "displayName": "BDD VSCode Runner",
  "description": "Run Cucumber scenarios through canonical Maven feature-line execution",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.119.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:bdd-vscode-runner.runCurrentScenario",
    "onCommand:bdd-vscode-runner.cancelRun",
    "workspaceContains:**/*.feature"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bdd-vscode-runner.runCurrentScenario",
        "title": "BDD Runner: Run Current Scenario"
      },
      {
        "command": "bdd-vscode-runner.cancelRun",
        "title": "BDD Runner: Cancel Active Run"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
